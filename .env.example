# Supabase (B2C 와 공유 — main repo 의 .env.local 에서 그대로 복사)
NEXT_PUBLIC_SUPABASE_URL=https://obxvucyhzlakensopalf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (트랜잭션 이메일 — 가입·인증·취소 안내)
RESEND_API_KEY=

# 도메인 (이메일 본문 link, redirect 등)
NEXT_PUBLIC_B2B_URL=https://seller.jimscanner.co.kr

# 국세청 사업자등록정보 진위확인 API (https://www.data.go.kr 신청)
NTS_BUSINESS_API_KEY=

# 한국수출입은행 환율 API
KOREAEXIM_API_KEY=

# ─────────────────────────────────────────────
# 24h 자율 agent 운영 (선택 — agent cron 사용 시만)
# 참조: _memory/agent-decision-rules.md
# ─────────────────────────────────────────────

# GitHub PAT (issue create + comment read). repo scope 필요.
# 발급: https://github.com/settings/tokens/new?scopes=repo&description=jimscanner-seller-agent
AGENT_GITHUB_TOKEN=
# 기본은 origin/main repo. 다른 repo 에 issue 만들 거면 override.
AGENT_GITHUB_REPO=anteam7/jimscanner-seller

# agent 가 외부 가입·로그인 시 사용할 사용자 신원
AGENT_PRIMARY_EMAIL=
AGENT_PRIMARY_USERNAME=
AGENT_PRIMARY_PASS_LEGACY=
AGENT_PRIMARY_PASS_STRONG=
