{
  "manifest_version": 3,
  "name": "짐스캐너 SELLER 수집기",
  "version": "0.2.0",
  "description": "해외 매입처 영수증 수집 + amazon checkout 배대지 주소 자동입력 + 배대지 배송신청서 HTML 캡쳐.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://*.amazon.com/*",
    "https://www.amazon.co.jp/*",
    "https://*.amazon.co.jp/*",
    "https://seller.jimscanner.co.kr/*",
    "https://*.jimscanner.co.kr/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "https://*.malltail.com/*",
    "https://*.jimpass.com/*",
    "https://*.ehanex.com/*",
    "https://*.hoottown.com/*",
    "https://*.iporter.com/*",
    "https://*.ohmyzip.com/*",
    "https://*.geniezip.com/*",
    "https://*.gajida.net/*",
    "https://*.gajida.com/*",
    "https://*.bidpot.co.kr/*",
    "https://*.sevenzone.com/*",
    "https://*.yesship.com/*",
    "https://*.eldex.co.kr/*",
    "https://*.araku.co.kr/*",
    "https://*.uniauc.com/*",
    "https://*.easytao.co.kr/*",
    "https://*.jiggujiggu.com/*",
    "https://*.2fasts.com/*",
    "https://*.post-go.co.kr/*",
    "https://*.postteam.co.kr/*",
    "https://*.thessanchina.co.kr/*",
    "https://*.tabae.co.kr/*",
    "https://*.tabaejapan.co.kr/*",
    "https://*.woomyshipping.com/*",
    "https://*.japantimemall.com/*",
    "https://*.joypost.co.kr/*",
    "https://*.chinaroad11.com/*",
    "https://*.kenzpost.com/*",
    "https://*.irasshaimase.co.kr/*",
    "https://*.triolink.co.kr/*",
    "https://*.hoyausa.co.kr/*",
    "https://ship.itemscout.io/*"
  ],
  "action": {
    "default_title": "짐스캐너 SELLER",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/gp/your-account/order-details*",
        "https://www.amazon.com/gp/your-account/order-history*",
        "https://www.amazon.com/gp/css/order-history*",
        "https://www.amazon.com/your-orders*"
      ],
      "js": ["scrapers/amazon-us.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.amazon.co.jp/gp/your-account/order-details*",
        "https://www.amazon.co.jp/gp/your-account/order-history*",
        "https://www.amazon.co.jp/gp/css/order-history*",
        "https://www.amazon.co.jp/your-orders*"
      ],
      "js": ["scrapers/amazon-jp.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.amazon.com/checkout/*",
        "https://www.amazon.com/gp/buy/*",
        "https://www.amazon.co.jp/checkout/*",
        "https://www.amazon.co.jp/gp/buy/*"
      ],
      "js": ["checkout/amazon-checkout.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.malltail.com/*",
        "https://*.jimpass.com/*",
        "https://*.ehanex.com/*",
        "https://*.hoottown.com/*",
        "https://*.iporter.com/*",
        "https://*.ohmyzip.com/*",
        "https://*.geniezip.com/*",
        "https://*.gajida.net/*",
        "https://*.gajida.com/*",
        "https://*.bidpot.co.kr/*",
        "https://*.sevenzone.com/*",
        "https://*.yesship.com/*",
        "https://*.eldex.co.kr/*",
        "https://*.araku.co.kr/*",
        "https://*.uniauc.com/*",
        "https://*.easytao.co.kr/*",
        "https://*.jiggujiggu.com/*",
        "https://*.2fasts.com/*",
        "https://*.post-go.co.kr/*",
        "https://*.postteam.co.kr/*",
        "https://*.thessanchina.co.kr/*",
        "https://*.tabae.co.kr/*",
        "https://*.tabaejapan.co.kr/*",
        "https://*.woomyshipping.com/*",
        "https://*.japantimemall.com/*",
        "https://*.joypost.co.kr/*",
        "https://*.chinaroad11.com/*",
        "https://*.kenzpost.com/*",
        "https://*.irasshaimase.co.kr/*",
        "https://*.triolink.co.kr/*",
        "https://*.hoyausa.co.kr/*",
        "https://ship.itemscout.io/*"
      ],
      "js": ["forwarders/capture-shipping-form.js", "forwarders/generic-form-filler.js"],
      "run_at": "document_idle"
    }
  ]
}
